---
interface Props {
  slug: string;
  name: string;
  brand: string;
  model: string;
  category: string;
  status: string;
  image: string;
  tags: string[];
}
const { slug, name, brand, model, category, status, image, tags } = Astro.props;

const statusColor: Record<string, string> = {
  '可用': 'bg-green-100 text-green-800',
  '使用中': 'bg-yellow-100 text-yellow-800',
  '维修中': 'bg-red-100 text-red-800',
};
---
<a
  href={`/equipment/${slug}`}
  class="device-card block bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-100 overflow-hidden"
  data-category={category}
  data-status={status}
  data-tags={tags.join(',')}
  data-search={`${name} ${brand} ${model} ${tags.join(' ')}`.toLowerCase()}
>
  <div class="aspect-video bg-gray-100 overflow-hidden">
    <img
      src={image}
      alt={name}
      class="w-full h-full object-cover"
      loading="lazy"
      onerror="this.src='/images/placeholder.svg'"
    />
  </div>
  <div class="p-4">
    <div class="flex items-start justify-between gap-2 mb-1">
      <h3 class="font-semibold text-gray-900 leading-tight">{name}</h3>
      <span class={`shrink-0 text-xs px-2 py-0.5 rounded-full font-medium ${statusColor[status] ?? 'bg-gray-100 text-gray-600'}`}>
        {status}
      </span>
    </div>
    <p class="text-sm text-gray-500 mb-2">{brand} · {model}</p>
    <div class="flex flex-wrap gap-1">
      <span class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded-full">{category}</span>
      {tags.slice(0, 2).map(t => (
        <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">{t}</span>
      ))}
    </div>
  </div>
</a>
