---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import DeviceCard from '../components/DeviceCard.astro';

const allDevices = await getCollection('equipment');
allDevices.sort((a, b) => a.data.category.localeCompare(b.data.category, 'zh'));

const categories = [...new Set(allDevices.map(d => d.data.category))].sort((a, b) => a.localeCompare(b, 'zh'));
const statuses = ['可用', '使用中', '维修中', '待到货'];
---
<Layout>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-1">设备库</h1>
    <p class="text-gray-500">共 {allDevices.length} 台设备</p>
  </div>

  <!-- Filter + Search Bar -->
  <div class="bg-white rounded-xl border border-gray-200 p-4 mb-6 flex flex-wrap gap-3 items-center">
    <input
      id="search"
      type="text"
      placeholder="搜索设备名称、品牌、型号..."
      class="flex-1 min-w-48 border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
    />
    <div class="flex flex-wrap gap-2 items-center">
      <span class="text-xs text-gray-400 font-medium">类别：</span>
      <button class="filter-btn active text-xs px-3 py-1.5 rounded-full border border-blue-500 bg-blue-50 text-blue-700" data-filter-type="category" data-filter-value="">全部</button>
      {categories.map(cat => (
        <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-gray-200 text-gray-600 hover:border-blue-400 hover:text-blue-600" data-filter-type="category" data-filter-value={cat}>{cat}</button>
      ))}
    </div>
    <div class="flex flex-wrap gap-2 items-center">
      <span class="text-xs text-gray-400 font-medium">状态：</span>
      <button class="filter-btn active text-xs px-3 py-1.5 rounded-full border border-blue-500 bg-blue-50 text-blue-700" data-filter-type="status" data-filter-value="">全部</button>
      {statuses.map(s => (
        <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-gray-200 text-gray-600 hover:border-blue-400 hover:text-blue-600" data-filter-type="status" data-filter-value={s}>{s}</button>
      ))}
    </div>
  </div>

  <!-- Device Grid -->
  <div id="device-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    {allDevices.map(device => (
      <DeviceCard
        slug={device.id}
        name={device.data.name}
        brand={device.data.brand}
        model={device.data.model}
        category={device.data.category}
        status={device.data.status}
        image={device.data.image}
        tags={device.data.tags}
      />
    ))}
  </div>

  <p id="no-results" class="hidden text-center text-gray-400 py-16">没有符合条件的设备</p>
</Layout>

<script>
  const searchInput = document.getElementById('search') as HTMLInputElement;
  const grid = document.getElementById('device-grid')!;
  const noResults = document.getElementById('no-results')!;
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');

  let activeCategory = '';
  let activeStatus = '';

  function applyFilters() {
    const q = searchInput.value.toLowerCase().trim();
    const cards = grid.querySelectorAll<HTMLElement>('.device-card');
    let visible = 0;

    cards.forEach(card => {
      const matchCat = !activeCategory || card.dataset.category === activeCategory;
      const matchStatus = !activeStatus || card.dataset.status === activeStatus;
      const matchSearch = !q || (card.dataset.search ?? '').includes(q);
      const show = matchCat && matchStatus && matchSearch;
      card.parentElement!.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults.classList.toggle('hidden', visible > 0);
  }

  searchInput.addEventListener('input', applyFilters);

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.filterType!;
      const value = btn.dataset.filterValue!;

      filterBtns.forEach(b => {
        if (b.dataset.filterType === type) {
          b.classList.remove('active', 'border-blue-500', 'bg-blue-50', 'text-blue-700');
          b.classList.add('border-gray-200', 'text-gray-600');
        }
      });
      btn.classList.add('active', 'border-blue-500', 'bg-blue-50', 'text-blue-700');
      btn.classList.remove('border-gray-200', 'text-gray-600');

      if (type === 'category') activeCategory = value;
      if (type === 'status') activeStatus = value;
      applyFilters();
    });
  });
</script>
